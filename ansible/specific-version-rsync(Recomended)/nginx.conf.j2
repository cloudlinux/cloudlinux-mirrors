{% if certbot_enabled | default(false) %}
# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name {{ mirror_domain }};
    
    # ACME challenge location for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root {{ certbot_webroot | default('/var/www/mirrors/acme') }};
    }

    # Required by cl-mirrors mirrorservice (health-check)
    location = /healthcheck {
        alias {{ healthcheck_file }};
        default_type text/html;
    }

    # Required by cl-mirrors mirrorservice (machine-readable JSON, post-2026-06-12 contract)
    location = /healthcheck.json {
        alias {{ healthcheck_json_file }};
        default_type application/json;
        add_header Cache-Control "no-store";
    }

    # Normalize SWNG path (no trailing slash)
    location = /swng {
        return 301 https://$server_name/swng/;
    }
    
    # Redirect all other traffic to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}
{% else %}
server {
    listen 80;
    listen [::]:80;
    server_name _;
    root {{ mirror_base_path }};
    index index.html;

    # Enable directory listing
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    # Logging
    access_log /var/log/nginx/swng-{{ cloudlinux_version }}-mirror-access.log;
    error_log /var/log/nginx/swng-{{ cloudlinux_version }}-mirror-error.log;

    # SWNG CloudLinux {{ cloudlinux_version }} repositories
    location / {
        try_files $uri $uri/ =404;
    }

    # Optional SWNG prefix for mixed setups
    location = /swng {
        return 301 /swng/;
    }

    location /swng/ {
        alias {{ mirror_base_path }}/swng/;
        autoindex on;
    }

    # Allow large file downloads
    client_max_body_size 0;
}
{% endif %}
