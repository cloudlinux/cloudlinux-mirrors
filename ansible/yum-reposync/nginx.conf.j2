server {
    listen 80;
    listen [::]:80;
    server_name {{ mirror_domain }};
    root {{ swng_mirror_path }};
    index index.html;

    # Enable directory listing
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    # Logging
    access_log /var/log/nginx/swng-reposync-mirror-access.log;
    error_log /var/log/nginx/swng-reposync-mirror-error.log;

    # Health-check for mirrorservice
    location = /healthcheck {
        alias {{ healthcheck_file }};
        default_type text/html;
    }

    location = /healthcheck.json {
        alias {{ healthcheck_json_file }};
        default_type application/json;
        add_header Cache-Control "no-store";
    }

    # SWNG repositories
    location / {
        try_files $uri $uri/ =404;
    }

    # Optional SWNG prefix for mixed setups
    location /swng/ {
        alias {{ swng_mirror_path }}/;
        autoindex on;
    }

    location = /swng {
        return 301 /swng/;
    }

    # Allow large file downloads
    client_max_body_size 0;
}
