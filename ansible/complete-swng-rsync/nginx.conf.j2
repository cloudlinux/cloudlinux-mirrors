{% if certbot_enabled | default(false) %}
# HTTP to HTTPS redirect
server {
    listen 80;
    server_name {{ mirror_domain }};
    
    # ACME challenge location for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root {{ certbot_webroot | default('/var/www/mirrors/acme') }};
    }
    
    # Redirect all other traffic to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}
{% else %}
server {
    listen 80;
    server_name _;
    root {{ swng_mirror_path }};
    index index.html;

    # Enable directory listing
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    # Logging
    access_log /var/log/nginx/swng-mirror-access.log;
    error_log /var/log/nginx/swng-mirror-error.log;

    # SWNG repositories
    location / {
        try_files $uri $uri/ =404;
    }

    # Optional SWNG prefix for mixed setups
    location /swng/ {
        alias {{ swng_mirror_path }}/;
        autoindex on;
    }

    # Allow large file downloads
    client_max_body_size 0;
}
{% endif %}
